{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": [
		"node_modules",
		"dist",
		"build",
		"apps/*/dist",
		"*.conf",
		"*.lock",
		"*.md",
		"*.sql",
		"*.yml",
		"*.yaml",
		"*.env",
		"*.env.*",
		"*.log",
		"*.sh"
	],
	"arrowParens": "avoid",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"semi": false,
	"singleQuote": true,
	"jsxSingleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"singleAttributePerLine": false,
	"htmlWhitespaceSensitivity": "strict",
	"vueIndentScriptAndStyle": true,
	"proseWrap": "never",
	"insertPragma": false,
	"printWidth": 120,
	"requirePragma": false,
	"tabWidth": 4,
	"useTabs": true,
	"embeddedLanguageFormatting": "auto",
	"endOfLine": "lf",
	"insertFinalNewline": true,
	"sortPackageJson": {
		"sortScripts": true
	}
}
