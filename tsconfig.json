{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"declaration": true,
		"outDir": "dist",
		"rootDir": ".",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["bun", "node"]
	},
	"include": ["src/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"]
}
